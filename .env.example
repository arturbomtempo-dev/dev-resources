## Example environment variables for EmailJS integration
# Replace the placeholder values with your actual EmailJS credentials.

NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id_here
# Template ID for emails sent to yourself
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID_FOR_ME=your_template_id_for_me_here
# Template ID for emails sent to the sender
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID_FOR_SENDER=your_template_id_for_sender_here
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key_here